# --- Cloud (optional) ---
# Set GROQ_API_KEY to use Groq cloud LLM + local sentence-transformers for embeddings.
# Leave it blank to fall back to fully local Ollama inference.
GROQ_API_KEY=

# Groq model to use when GROQ_API_KEY is set
GROQ_MODEL=llama3-8b-8192

# --- Ollama (local fallback) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=mistral-nemo

# --- Sentence-transformers (embeddings when using Groq path) ---
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# --- Storage & chunking (shared) ---
CHROMA_DB_PATH=./data/chromadb
UPLOAD_DIR=./data/uploads
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K_RESULTS=5
# Minimum similarity score (0.0–1.0) a chunk must reach to be included in context.
# Raise this if you get irrelevant sources; lower it if relevant chunks are being filtered out.
RELEVANCE_SCORE_THRESHOLD=0.3
